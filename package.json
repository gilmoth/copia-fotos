{
  "name": "copia-fotos",
  "version": "1.0.0",
  "description": "Una aplicación de escritorio para organizar y copiar fotos y videos",
  "main": "main.js",
  "scripts": {
    "vite": "vite",
    "electron": "electron .",
    "dev": "concurrently \"npm run vite\" \"npm run electron\"",
    "build": "vite build",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.local.copiafotos",
    "productName": "Copia-fotos",
    "artifactName": "${productName} Portable.${ext}",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "portable"
      ]
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "asar": true
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "exifr": "^7.1.3"
  }
}